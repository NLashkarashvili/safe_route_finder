class DataLoader:
    """
    Class for loading various data needed for the safe route finder.
    """
    
    def __init__(self):
        """Initialize the data loader."""
        self.lsoa_gdf = None
        self.lsoa_crime_data = None
        
    def load_safety_pois(self, center_point, dist=800):
        """
        Load Points of Interest (POIs) that are relevant for safety calculations.
        
        Args:
            center_point: Tuple of (lat, lon) for the center point
            dist: Distance in meters to search for POIs
            
        Returns:
            GeoDataFrame containing POIs with safety relevance
        """
        tags = {
            'amenity': [
                'police', 'hospital', 'pharmacy',  
                'bar', 'pub', 'nightclub',         
                'cafe', 'restaurant',              
                'theatre', 'cinema', 'arts_centre' 
            ],
            'leisure': ['park', 'garden', 'nature_reserve'],
            'railway': ['station'],
            'public_transport': ['station', 'stop_position']
        }
        
        try:
            safety_pois = ox.geometries_from_point(center_point, tags, dist=dist)
            
            if not safety_pois.empty:
                safety_pois['safety_type'] = 'neutral'
                
                mask = safety_pois['amenity'].isin(['police', 'hospital', 'pharmacy'])
                safety_pois.loc[mask, 'safety_type'] = 'positive'
                
                mask = safety_pois['amenity'].isin(['bar', 'pub', 'nightclub'])
                safety_pois.loc[mask, 'safety_type'] = 'negative'
                
                mask = safety_pois['leisure'].isin(['park', 'garden', 'nature_reserve'])
                safety_pois.loc[mask, 'safety_type'] = 'positive'
                
                mask = safety_pois['public_transport'].notna()
                safety_pois.loc[mask, 'safety_type'] = 'neutral'
                
                return safety_pois
            else:
                return gpd.GeoDataFrame()
                
        except:
            return gpd.GeoDataFrame()
    
